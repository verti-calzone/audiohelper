entities.audiohelper/AdvancedAudioReplacer.attributes.description.IncrementMode=Increment the music parameter by the amount given, instead of setting it to that amount
entities.audiohelper/AdvancedAudioReplacer.attributes.description.ResetTime=Time in seconds to wait before resetting the music parameter

# Muter
entities.audiohelper/Muter.placements.name.muter=Muter
entities.audiohelper/Muter.placements.description.muter=Mutes all instances of a particular FMOD event
entities.audiohelper/Muter.attributes.description.EventToMute=FMOD event path of the event to mute

# Bus Muter
entities.audiohelper/BusMuter.placements.name.busmuter=Bus Muter
entities.audiohelper/BusMuter.placements.description.busmuter=Flag-toggled controller that mutes all sounds in the specified bus
entities.audiohelper/BusMuter.attributes.description.Flag=When this flag is set, all sounds in the bus will be muted



# MUSICAL ENTITIES

# Musical Booster
entities.audiohelper/MusicalBooster.placements.name.musicalbooster=Musical Booster
entities.audiohelper/MusicalBooster.placements.description.musicalbooster=A booster with customizable sounds, and sets a music parameter while the player is boosting
entities.audiohelper/MusicalBooster.attributes.description.EnterSound=FMOD event to play when the player enters the booster. Leave blank for no sound to occur
entities.audiohelper/MusicalBooster.attributes.description.StartSound=FMOD event to play when the player starts boosting. Leave blank for no sound to occur
entities.audiohelper/MusicalBooster.attributes.description.LoopSound=Red booster only, FMOD event to play while boosting. Leave blank for no sound to occur
entities.audiohelper/MusicalBooster.attributes.description.ExitSound=FMOD event to play when boosting is finished. Leave blank for no sound to occur
entities.audiohelper/MusicalBooster.attributes.description.SpawnSound=FMOD event to play when the booster respawns. Leave blank for no sound to occur
entities.audiohelper/MusicalBooster.attributes.description.MusicParameter=Music parameter to adjust while boosting, resetting once you leave the booster. Leave empty to not affect music
entities.audiohelper/MusicalBooster.attributes.description.Mode=Handles how to reset the music parameter. "Get" mode stores the previous parameter value before setting the parameter (prone to cause issues if more than one entity uses the same parameter). "Set" mode uses the value defined in the "Reset Parameter Value" field. Increment mode will add the "Parameter Value" to the parameter, then subtract it when resetting

# Musical Bumper
entities.audiohelper/MusicalBumper.placements.name.musicalbumper=Musical Bumper
entities.audiohelper/MusicalBumper.placements.description.musicalbumper=A bumper with customizable sounds, and briefly sets a music parameter when hit
entities.audiohelper/MusicalBumper.attributes.description.BumpSound=FMOD event to play when the bumper bumps the player. Leave blank for no sound to occur
entities.audiohelper/MusicalBumper.attributes.description.FireSound=FMOD event to play when the player dies to the bumper. Leave blank for no sound to occur
entities.audiohelper/MusicalBumper.attributes.description.SpawnSound=FMOD event to play when the bumper returns from its inactive state. Leave blank for no sound to occur
entities.audiohelper/MusicalBumper.attributes.description.MusicParameter=Music parameter to adjust while boosting, resetting once you leave the booster. Leave empty to not affect music
entities.audiohelper/MusicalBumper.attributes.description.Mode=Handles how to reset the music parameter. "Get" mode stores the previous parameter value before setting the parameter (prone to cause issues if more than one entity uses the same parameter). "Set" mode uses the value defined in the "Reset Parameter Value" field. Increment mode will add the "Parameter Value" to the parameter, then subtract it when resetting
entities.audiohelper/MusicalBumper.attributes.description.CoreState=How core mode affects this bumper

# Musical Swap Block
entities.audiohelper/MusicalSwapBlock.placements.name.musicalswapblock=Musical Swap Block
entities.audiohelper/MusicalSwapBlock.placements.description.musicalswapblock=A swap block with customizable sounds, and sets a music parameter while in motion
entities.audiohelper/MusicalSwapBlock.attributes.description.StartSound=FMOD event to play when the swapblock activates. Leave blank for no sound to occur
entities.audiohelper/MusicalSwapBlock.attributes.description.MoveSound=Looping FMOD event to play while the swapblock is moving towards its node (vanilla swapblocks don't actually use a sound here). Leave blank for no sound to occur
entities.audiohelper/MusicalSwapBlock.attributes.description.MoveEndSound=FMOD event to play when the swapblock reaches its node. Leave blank for no sound to occur
entities.audiohelper/MusicalSwapBlock.attributes.description.ReturnSound=Looping FMOD event to play while the swapblock retracts. Leave blank for no sound to occur
entities.audiohelper/MusicalSwapBlock.attributes.description.ReturnEndSound=FMOD event to play when the swapblock returns to its home. Leave blank for no sound to occur
entities.audiohelper/MusicalSwapBlock.attributes.description.EndMoveSoundWithParameter=Ends the move sound by setting an "end" parameter to 1 instead of stopping the looping event. Useful if you're using an event that needs a special ending, rather than fading out. Not recommended unless you know what you're doing in FMOD
entities.audiohelper/MusicalSwapBlock.attributes.description.EndReturnSoundWithParameter=Ends the return sound by setting an "end" parameter to 1 instead of stopping the looping event, which is how vanilla does it. Useful if you're using an event that needs a special ending, rather than fading out. Not recommended unless you know what you're doing in FMOD
entities.audiohelper/MusicalSwapBlock.attributes.description.MusicParameter=Music parameter to adjust while the block is activated. Leave empty to not affect music
entities.audiohelper/MusicalSwapBlock.attributes.description.Mode=Handles how to reset the music parameter. "Get" mode stores the previous parameter value before setting the parameter (prone to cause issues if more than one entity uses the same parameter). "Set" mode uses the value defined in the "Reset Parameter Value" field. Increment mode will add the "Parameter Value" to the parameter, then subtract it when resetting
entities.audiohelper/MusicalSwapBlock.attributes.description.ResetBeforeReturn=Resets the parameter once the swapblock starts retracting, instead of when it returns to its home

# Musical Move Block
entities.audiohelper/MusicalMoveBlock.placements.name.musicalmoveblock=Musical Move Block
entities.audiohelper/MusicalMoveBlock.placements.description.musicalmoveblock=A Move Block with customizable sounds, and sets a music parameter while in motion. Also customizes how steering the block affects the moving sound
entities.audiohelper/MusicalMoveBlock.attributes.description.ActivateSound=FMOD event to play when the block is activated. Leave blank for no sound to occur
entities.audiohelper/MusicalMoveBlock.attributes.description.MoveSound=Looping FMOD event to play while the block is moving. Uses "arrow_influence" and "arrow_stop" parameters, and expects the FMOD event to be formatted accordingly. Leave blank for no sound to occur
entities.audiohelper/MusicalMoveBlock.attributes.description.BreakSound=FMOD event to play when the block breaks.Leave blank for no sound to occur
entities.audiohelper/MusicalMoveBlock.attributes.description.ReformSound=FMOD event to play while the block reforms. Leave blank for no sound to occur
entities.audiohelper/MusicalMoveBlock.attributes.description.ReappearSound=FMOD event to play when the block finishes reappearing. Leave blank for no sound to occur
entities.audiohelper/MusicalMoveBlock.attributes.description.MusicParameter=Music parameter to adjust while the block is activated. Leave empty to not affect music
entities.audiohelper/MusicalMoveBlock.attributes.description.Mode=Handles how to reset the music parameter. "Get" mode stores the previous parameter value before setting the parameter (prone to cause issues if more than one entity uses the same parameter). "Set" mode uses the value defined in the "Reset Parameter Value" field. Increment mode will add the "Parameter Value" to the parameter, then subtract it when resetting

# Musical Kevin
entities.audiohelper/MusicalKevin.placements.name.musicalkevin=Musical Kevin
entities.audiohelper/MusicalKevin.placements.description.musicalkevin=A Kevin with customizable sounds, and sets a music parameter while in motion
entities.audiohelper/MusicalKevin.attributes.description.ActivateSound=FMOD event to play when the Kevin is activated. Leave blank for no sound to occur
entities.audiohelper/MusicalKevin.attributes.description.MoveSound=Looping FMOD event to play while the Kevin is "attacking". Has a "suberged" parameter for when the Kevin is underwater. Leave blank for no sound to occur
entities.audiohelper/MusicalKevin.attributes.description.ImpactSound=FMOD event to play when the Kevin hits something. Leave blank for no sound to occur
entities.audiohelper/MusicalKevin.attributes.description.ReturnSound=Looping FMOD event to play while the Kevin is moving back to its home. Leave blank for no sound to occur
entities.audiohelper/MusicalKevin.attributes.description.WaypointSound=FMOD event to play when the Kevin reaches each waypoint on its way home. Leave blank for no sound to occur
entities.audiohelper/MusicalKevin.attributes.description.RestSound=FMOD event to play when the Kevin returns to its home. Leave blank for no sound to occur
entities.audiohelper/MusicalKevin.attributes.description.MusicParameter=Music parameter to adjust while the Kevin is activated. Leave empty to not affect music
entities.audiohelper/MusicalKevin.attributes.description.Mode=Handles how to reset the music parameter. "Get" mode stores the previous parameter value before setting the parameter (prone to cause issues if more than one entity uses the same parameter). "Set" mode uses the value defined in the "Reset Parameter Value" field. Increment mode will add the "Parameter Value" to the parameter, then subtract it when resetting

# Musical Zip Mover
entities.audiohelper/MusicalZipMover.placements.name.musicalzipmover=Musical Zip Mover
entities.audiohelper/MusicalZipMover.placements.description.musicalzipmover=A zip mover with customizable sounds and timings, and sets a music parameter while in motion
entities.audiohelper/MusicalZipMover.attributes.description.MoveTime=Time in seconds for the zip mover to reach its node after it begins moving (a 0.1 second delay is always present before it starts moving)
entities.audiohelper/MusicalZipMover.attributes.description.HoldTime=Time in seconds that the zip mover waits at its node before it starts returning
entities.audiohelper/MusicalZipMover.attributes.description.ReturnTime=Time in seconds for the zip mover to reach its home from its node
