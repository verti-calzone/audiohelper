# NEW ENTITIES

# Bell
entities.audiohelper/Bell.placements.name.bell=Bell
entities.audiohelper/Bell.placements.description.bell=Plays a note when the player passes through it. Will be louder the faster the player is going
entities.audiohelper/Bell.attributes.description.VolumeBoost=Adds a bit of volume to the bell by pretending the player has more speed. Set to 0 for base behaviour. Set to 1 to have all rings act as if the player is at the max speed
entities.audiohelper/Bell.attributes.description.SetFlag=Sets a flag when the bell is rung. Leave blank to not set a flag

# Musical Bell
entities.audiohelper/MusicalBell.placements.name.musicalbell=Musical Bell
entities.audiohelper/MusicalBell.placements.description.musicalbell=Bell that affects a music parameter
entities.audiohelper/MusicalBell.attributes.description.VolumeBoost=Adds a bit of volume to the bell by pretending the player has more speed. Set to 0 for base behaviour. Set to 1 to have all rings act as if the player is at the max speed
entities.audiohelper/MusicalBell.attributes.description.SetFlag=Sets a flag when the bell is rung. Leave blank to not set a flag
entities.audiohelper/MusicalBell.attributes.description.MusicParameter=Music parameter to adjust when rung, resetting after the time specified
entities.audiohelper/MusicalBell.attributes.description.IncrementMode=Increment the music parameter by the amount given, instead of setting it to that amount
entities.audiohelper/MusicalBell.attributes.description.Timer=How long until the parameter resets

# Music Parameter Sound Source
entities.audiohelper/MusicParameterSoundSource.placements.name.musicparametersoundsource=Music Parameter Sound Source
entities.audiohelper/MusicParameterSoundSource.placements.description.musicparametersoundsource=Fades a music parameter as the player gets closer to this entity, mimicking a sound source entity
entities.audiohelper/MusicParameterSoundSource.attributes.description.MusicParameter=Music parameter to set
entities.audiohelper/MusicParameterSoundSource.attributes.description.EdgeValue=Value to set the parameter to at the edge of the radius
entities.audiohelper/MusicParameterSoundSource.attributes.description.CentreValue=Value to set the parameter to at the centre of the radius
entities.audiohelper/MusicParameterSoundSource.attributes.description.Radius=Radius of the area in tiles where the parameter should be affected



# ONDASH ENTITIES

# Play Sound On Dash
entities.audiohelper/PlaySoundOnDash.placements.name.playsoundondash=Play Sound on Dash
entities.audiohelper/PlaySoundOnDash.placements.description.playsoundondash=Plays an FMOD event when the player dashes. The parameter is set to 1 = left, 2 = up-left, etc, and expects the FMOD event to be formatted accordingly

# Set Music Param On Dash
entities.audiohelper/SetMusicParamOnDash.placements.name.setmusicparamondash=Set Music Param On Dash
entities.audiohelper/SetMusicParamOnDash.placements.description.setmusicparamondash=Sets a parameter in the music event when the player dashes. The parameter is set to 1 = left, 2 = up-left, etc, and expects the FMOD event to be formatted accordingly
entities.audiohelper/SetMusicParamOnDash.attributes.description.parameter=Music parameter to set. The parameter is set to 1 = left, 2 = up-left, etc, and expects the FMOD event to be formatted accordingly

# Play Sound On Directional Dash
entities.audiohelper/PlaySoundOnDirectionalDash.placements.name.playsoundondirectionaldash=Play Sound on Directional Dash
entities.audiohelper/PlaySoundOnDirectionalDash.placements.description.playsoundondirectionaldash=Plays a unique FMOD event for each dash direction
entities.audiohelper/PlaySoundOnDirectionalDash.attributes.description.eventL=Event to play when the player dashes left. Leave blank for no sound
entities.audiohelper/PlaySoundOnDirectionalDash.attributes.description.eventUL=Event to play when the player dashes up-left. Leave blank for no sound
entities.audiohelper/PlaySoundOnDirectionalDash.attributes.description.eventU=Event to play when the player dashes up. Leave blank for no sound
entities.audiohelper/PlaySoundOnDirectionalDash.attributes.description.eventUR=Event to play when the player dashes up-right. Leave blank for no sound
entities.audiohelper/PlaySoundOnDirectionalDash.attributes.description.eventR=Event to play when the player dashes right. Leave blank for no sound
entities.audiohelper/PlaySoundOnDirectionalDash.attributes.description.eventDR=Event to play when the player dashes down-right. Leave blank for no sound
entities.audiohelper/PlaySoundOnDirectionalDash.attributes.description.eventD=Event to play when the player dashes down. Leave blank for no sound
entities.audiohelper/PlaySoundOnDirectionalDash.attributes.description.eventDL=Event to play when the player dashes down-left. Leave blank for no sound



# CONTROLLER ENTITIES

# Custom Cassette Block Manager
entities.audiohelper/CustomCassetteBlockManager.placements.name.customcassetteblockmanager=Custom Cassette Block Manager (WIP)
entities.audiohelper/CustomCassetteBlockManager.placements.description.customcassetteblockmanager=Flag-toggled controller that gives more control over cassette music
entities.audiohelper/CustomCassetteBlockManager.attributes.description.Tempo=Tempo of the music, referring to the speed of the ticking metornome
entities.audiohelper/CustomCassetteBlockManager.attributes.description.CountInLength=Length of the "count-in" where the blocks tick before the music enters. Measured in notes, not ticks of the metronome
entities.audiohelper/CustomCassetteBlockManager.attributes.description.LoopStart=Point at which the song loops back to
entities.audiohelper/CustomCassetteBlockManager.attributes.description.LoopEnd=Point at which the song loops
entities.audiohelper/CustomCassetteBlockManager.attributes.description.NotesPerTick=Number of notes between each tick of the metronome
entities.audiohelper/CustomCassetteBlockManager.attributes.description.TicksPerSwap=Number of ticks between each block change
entities.audiohelper/CustomCassetteBlockManager.attributes.description.StartingColour=Colour of block to start the sequence at. Also affects the "target" colour to be on first after respawning
entities.audiohelper/CustomCassetteBlockManager.attributes.description.NumberOfBlocks=Number of blocks in the cycle
entities.audiohelper/CustomCassetteBlockManager.attributes.description.MusicParameter=Name of the parameter that controls the music in FMOD
entities.audiohelper/CustomCassetteBlockManager.attributes.description.NoteOffset=Number of notes "ahead" the music is, compared to the timing of the blocks. Will skip this many notes from the start of the song when it begins. Should be set to 5 for the Farewell cassette track to work properly
entities.audiohelper/CustomCassetteBlockManager.attributes.description.CassetteSong=Song to play. Leave empty to use the main level music instead
entities.audiohelper/CustomCassetteBlockManager.attributes.description.TickSound=FMOD event to play when the metronome ticks, but the blocks do not change. Leave empty to have no sound
entities.audiohelper/CustomCassetteBlockManager.attributes.description.SwapSound=FMOD event to play when the blocks change. Leave empty to have no sound
entities.audiohelper/CustomCassetteBlockManager.attributes.description.UsesFlag=Whether this manager will only be active when the flag is set
entities.audiohelper/CustomCassetteBlockManager.attributes.description.Flag=Flag to use if "Uses Flag" is enabled
entities.audiohelper/CustomCassetteBlockManager.attributes.description.FreezeMode=If no managers are active, freezes the blocks in their current state. If all managers are inactive and none of them use freeze mode, then the blocks will be disabled

